         <font>
            <Font name="Verdana Bold" size="34.0" />
         </font>
      </Label>
      <Rectangle arcHeight="50.0" arcWidth="50.0" fill="#ffffff4a" height="641.0" layoutX="-14.0" layoutY="-13.0" stroke="BLACK" strokeType="INSIDE" width="231.0" />
      <ImageView fitHeight="100.0" fitWidth="113.0" layoutX="574.0" layoutY="395.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/cancelReservation.png" />
