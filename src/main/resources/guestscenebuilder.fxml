      </ImageView>
      <ImageView fitHeight="100.0" fitWidth="127.0" layoutX="676.0" layoutY="214.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/viewReservation.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="100.0" fitWidth="113.0" layoutX="907.0" layoutY="214.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/makeReservation.png" />
         </image>
      </ImageView>
      <Button fx:id="buttonViewRooms" layoutX="448.0" layoutY="319.0" mnemonicParsing="false" onAction="#switchToViewRooms" prefHeight="27.0" prefWidth="148.0" styleClass="btn-round" stylesheets="@Style.css" text="view rooms" textAlignment="CENTER" textFill="#fcfcfb" />
